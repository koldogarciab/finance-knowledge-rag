# Copy this file to .env and add only the credentials you actually use.

OPENAI_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=

# Local Ollama generation - no external API or token charges
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_TEMPERATURE=0
OLLAMA_NUM_PREDICT=512
OLLAMA_KEEP_ALIVE=5m
